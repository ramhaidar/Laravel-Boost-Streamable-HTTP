{
    "name": "ramhaidar/laravel-boost-streamable-http",
    "description": "Unofficial opt-in Streamable HTTP / web MCP transport for Laravel Boost.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "boost",
        "mcp",
        "streamable-http",
        "ai"
    ],
    "homepage": "https://github.com/ramhaidar/laravel-boost-streamable-http",
    "authors": [
        {
            "name": "ramhaidar",
            "homepage": "https://github.com/ramhaidar",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/ramhaidar/laravel-boost-streamable-http/issues",
        "source": "https://github.com/ramhaidar/laravel-boost-streamable-http",
        "docs": "https://github.com/ramhaidar/laravel-boost-streamable-http#readme"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/boost": "^2.0",
        "laravel/mcp": "^0.7.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.5|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ramhaidar\\LaravelBoostStreamableHttp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ramhaidar\\LaravelBoostStreamableHttp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ramhaidar\\LaravelBoostStreamableHttp\\LaravelBoostStreamableHttpServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "test:lint": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=-1"
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
